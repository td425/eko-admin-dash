  "scripts": {
    "start": "vite serve",
    "serve": "node server.js",
    "build": "vite build",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*\"",
    "typecheck": "tsc --noEmit",
    "fix": "yarn lint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "update-api-docs": "ts-node docs/update-api-docs.ts"
  },
  "prettier": {
    "printWidth": 120,
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": false,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "arrowParens": "avoid"
